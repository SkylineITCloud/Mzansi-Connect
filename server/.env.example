# Copy this to .env and fill in values. Never commit .env.

PORT=3000
NODE_ENV=development

# Admin API key — generate a long random string for protected endpoints
ADMIN_API_KEY=generate-a-long-random-secret-here

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,https://your-production-domain.com

# Rate limiting
RATE_LIMIT_MAX=200
CONTACT_RATE_LIMIT_MAX=5
